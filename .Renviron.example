# Google Sheet ID (used when no URL is pasted in the app UI)
SHEET_ID=your_sheet_id_here
SHEET_NAME=sheet_with_listings

# Service-account mode for real-time writeback in hosted deployments.
# When true, app authenticates using GCP_SA_JSON and users must share
# their sheets with SERVICE_ACCOUNT_EMAIL (Editor access).
# SERVICE_ACCOUNT_MODE=true
# SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GCP_SA_JSON={...single-line-json...}

# Set to true to run in public-link mode (no Google OAuth in app).
# The target sheet/tab must be shared appropriately for public reading.
# PUBLIC_LINK_MODE=true

# Local development: desktop / installed OAuth client
clientType=installed
clientID=
clientSecret=

# Optional: preselect one Google account and avoid the chooser dialog
# when multiple cached accounts exist.
# GARGLE_OAUTH_EMAIL=you@example.com

# Posit Connect Cloud production: web OAuth client
# clientType=web
# clientID=your_web_oauth_client_id
# clientSecret=your_web_oauth_client_secret
# clientRedirectUris=https://<your-connect-domain>/
# If your GCP app requires an explicit callback path, use the exact URI
# registered in Google Cloud Console.

# Optional: noninteractive fallback for Connect Cloud
# Store a base64-encoded serialized OAuth token as a secret variable.
# GS4_OAUTH_TOKEN_B64=
# If the token is too long, split it into numbered chunks:
# GS4_OAUTH_TOKEN_B64_1=
# GS4_OAUTH_TOKEN_B64_2=
